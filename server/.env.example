# SmartStay backend release configuration
# Never place real secrets in this example file.

NODE_ENV=production
DEPLOYMENT_ENV=staging
PORT=3001

CLIENT_ORIGINS=https://staging.example.com
TRUST_PROXY=1

SERVICE_NAME=smartstay-backend
RELEASE_SHA=replace-with-git-commit-sha
RUNTIME_STATE_MODE=in-memory-single-instance
LOG_ERROR_STACKS=false
SHUTDOWN_TIMEOUT_MS=10000
JSON_BODY_LIMIT=256kb

# Frontend build URL checked by the release gate.
VITE_API_URL=/api

# Destination provider
GEOAPIFY_API_KEY=replace-with-secret

# Active accommodation provider
LITEAPI_API_KEY=replace-with-secret
LITEAPI_BASE_URL=https://api.liteapi.travel/v3.0
LITEAPI_WHITELABEL_BASE_URL=https://replace-with-approved-checkout-domain.example
LITEAPI_DEFAULT_CURRENCY=EUR
LITEAPI_DEFAULT_GUEST_NATIONALITY=IT
LITEAPI_TIMEOUT_SECONDS=12
LITEAPI_RESULTS_LIMIT=80

# RouteStack remains disabled and is not required for release.
# ROUTESTACK_BASE_URL=
# ROUTESTACK_API_KEY=
# ROUTESTACK_API_SECRET=
