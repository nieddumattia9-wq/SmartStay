{
  "name": "smartstay",
  "private": true,
  "version": "0.0.0",
  "description": "SmartStay Frontend",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:engine-v2 && npm run test:lifecycle && npm run test:security && npm run test:release && npm run test:analytics",
    "test:engine-v2": "node scripts/run-engine-v2-tests.mjs",
    "test:golden": "node scripts/run-engine-v2-tests.mjs --golden",
    "test:calibration": "node scripts/run-engine-v2-tests.mjs --calibration",
    "test:ranking": "node scripts/run-engine-v2-tests.mjs --ranking",
    "test:lifecycle": "node --test tests/lifecycle/*.test.mjs",
    "test:security": "node --test tests/security/*.test.mjs",
    "test:release": "node --test tests/release/*.test.mjs",
    "test:analytics": "node --test tests/analytics/*.test.mjs",
    "validate:analytics": "node scripts/validate-analytics-contract.mjs",
    "audit:security": "node scripts/run-security-dependency-audit.mjs",
    "check:release-env": "node scripts/check-release-environment.mjs",
    "smoke:staging:local": "node scripts/run-staging-runtime-smoke.mjs --local",
    "smoke:staging": "node scripts/run-staging-runtime-smoke.mjs",
    "release:ci": "npm run typecheck && npm test && npm run gate:analytics-beta && npm run build && npm run audit:security && npm run smoke:staging:local",
    "release:gate": "npm run release:ci && npm run check:release-env",
    "release:candidate": "node scripts/create-release-candidate.mjs",
    "release:verify": "node scripts/verify-release-candidate.mjs",
    "release:evidence": "node scripts/verify-production-release-evidence.mjs",
    "rollback:verify": "node scripts/verify-rollback-target.mjs",
    "gate:analytics-beta": "node scripts/run-analytics-beta-measurement-gate.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
